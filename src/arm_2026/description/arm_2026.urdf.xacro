<?xml version="1.0"?>
<robot name="arm_2026" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.05"/>
      </geometry>
    </visual>
  </link>

  <link name="base_link_1">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.10"/>
      </geometry>
    </visual>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0.10 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.04 0.04"/>
      </geometry>
    </visual>
  </link>

  <link name="elbow_link">
    <visual>
      <origin xyz="0.10 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.03 0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="base_link_1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="60.0"/>
  </joint>

  <joint name="shoulder_extension" type="revolute">
    <parent link="base_link_1"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="0.2"/>
  </joint>

  <joint name="elbow_extension" type="revolute">
    <parent link="shoulder_link"/>
    <child link="elbow_link"/>
    <origin xyz="0.20 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="0.2"/>
  </joint>

  <ros2_control name="Arm2026Hardware" type="system">
    <hardware>
      <plugin>arm_2026/Arm2026System</plugin>
    </hardware>

    <joint name="base_yaw">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

    <joint name="shoulder_extension">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

    <joint name="elbow_extension">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

</robot>
